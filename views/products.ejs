<% 
const inventoryValue = products.reduce((acc, curr)=>{
  acc += curr.qty * curr.price
  return acc
},0 )


const lowStockNumber = products.filter(p => p.qty <= 20).length

const OutOfStockNumber = products.filter(p => p.qty === 0).length

const availableTypes = new Set()
products.forEach(p => availableTypes.add(p.type))

const availableSuppliers = new Set()
products.forEach(p => availableSuppliers.add(p.supplier))
%>


<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <main><%- include('header') %></main>
    <h1 class="big-title">Products</h1>
    <section class="overview">
      <h2>Overview</h1>
      <div class="info">
        <div>
          <h3>Total <br> products</h2>
          <p><%= products.length %></p>
        </div>
        <div>
          <h3>Inventory <br> value</h2>
          <p class=""><%= inventoryValue %>$</p>
        </div>
        <div class="low">
          <h3>Low stock</h2>
          <p><%= lowStockNumber %></p>
        </div>
        <div class="out">
          <h3>Out of <br> stock</h2>
          <p><%= OutOfStockNumber %></p>
        </div>
      </div>
    </section>
    <section class="filters">
      <h2>Filters</h2>
      <div class="inputs">
        <form class="p-form" action="/products"  method="GET">
          <input class="searchInput" name="name" type="search" placeholder="Product name ...">
          <div class="select1">
            <select name="type" id="">
            <option value="">Type</option>
            <% availableTypes.forEach(t=>{ %>
              <option value="<%= t %>"><%= t %></option>
            <% }) %>
          </select>
          </div>
          <div class="select2">
            <select name="supplier" id="">
            <option value="">Supplier</option>
            <% availableSuppliers.forEach(s=>{ %>
              <option value="<%= s %>"><%= s %></option>
            <% }) %>
          </select>
          </div>
     <div class="select3">
            <select name="availability" id="">
             <option value="all">All</option>
             <option value="on">On stock</option>
             <option value="out">Out of  stock</option>

           </select>
           
          </div>
          <button type="submit">Filter</button>
          <% if (isAdmin) { %>
            <label class="archive-toggle">
              <input type="checkbox" name="showArchived" value="true" <%= query.showArchived === "true" ? "checked" : "" %>>
              Show archived
            </label>
          <% } %>
        </form>
      </div>
    </section>
    <section class="products">
      <div class="products-header">
        <h2>Products</h2>
        <% if (isAdmin) { %>
          <a class="add-btn" href="/products/add">Add Product</a>
        <% } %>
      </div>
<div class="table-container">
        <table  border="0">
        <thead>
          <th>#</th>
          <th>Name</th>
          <th>Type</th>
          <th>Unit price</th>
          <th>QTY</th>
          <th>Supplier</th>
          <% if (isAdmin) { %>
            <th></th>
          <% } %>
        </thead>
        <tbody>
          <% filtred.map(p=> { %>
            <tr class="<%= p.archived ? "archived" : "" %>">
              <td><%= p.id %></td>
              <td class="name"><%= p.name %></td>
              <td class="diver"><%= p.type %></td>
              <td><%= p.price %></td>
              <td><%= p.qty %></td>
              <td class="diver"><%= p.supplier %></td>
              <% if (isAdmin) { %>
                <td class="actions">
                  <a class="edit-btn" href="/products/edit/<%= p.id %>">Edit</a>
                  <form action="/products/<%= p.id %>" method="POST">
                    <input type="hidden" name="_method" value="DELETE">
                    <button class="<%= p.archived ? "unarchive-btn" : "del-btn" %>" type="submit"><%= p.archived ? "Unarchive" : "Archive" %></button>
                  </form>
                </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
</div>
    </section>
  </body>
</html>
