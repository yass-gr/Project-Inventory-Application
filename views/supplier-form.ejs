<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= mode === "add" ? "Add" : "Edit" %> Supplier</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main><%- include('header') %></main>
    <section class="form-section">
      <form class="product-form" action="/suppliers<%= mode === "edit" ? "/" + supplier.id : "" %>" method="POST">
        <% if (mode === "edit") { %>
          <input type="hidden" name="_method" value="PUT">
        <% } %>
        <h2><%= mode === "add" ? "Add" : "Edit" %> Supplier</h2>
        <input type="text" name="name" placeholder="Name" value="<%= mode === "edit" ? supplier.supplier : "" %>" required>
        <button type="submit"><%= mode === "add" ? "Add" : "Update" %></button>
      </form>
    </section>
  </body>
</html>
