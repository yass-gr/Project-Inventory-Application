<% 
let max = 0;
const BestSupplier = suppliers.reduce((acc, curr)=>{
    if (Number(curr.products_supplied) > max){
        max = Number(curr.products_supplied)
        acc = curr.supplier
    }
    return acc
}, suppliers[0].supplier)
%>


<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="styles.css" />
  </head>
  <body>
    <main><%- include('header') %></main>
    <h1 class="big-title">Suppliers</h1>
    <section class="overview">
      <h2>Overview</h1>
      <div class="info">
        <div class="ovr-1">
          <h3>Total <br> suppliers</h2>
          <p><%= suppliers.length %></p>
        </div>
        <div class="ovr-2">
          <h3>Best <br> supplier</h2>
          <p class=""><%= BestSupplier %></p>
        </div>
        
      </div>
    </section>
    <section class="filters">
      <h2>Filters</h2>
      <div class="inputs">
        <form class="p-form" action="/suppliers"  method="GET">
          <input class="searchInput" name="name" type="search" placeholder="Supplier name ...">
          
          
         <div class="select4">
           <select name="availability" id="">
            <option value="all">All</option>
            <option value="on">Has products</option>
            <option value="out">No products</option>

          </select>
          
         </div>
           <button type="submit">Filter</button>
           <% if (isAdmin) { %>
             <label class="archive-toggle">
               <input type="checkbox" name="showArchived" value="true" <%= query.showArchived === "true" ? "checked" : "" %>>
               Show archived
             </label>
           <% } %>
         </form>
       </div>
     </section>
     <section class="products">
       <div class="products-header">
         <h2>Suppliers</h2>
         <% if (isAdmin) { %>
           <a class="add-btn" href="/suppliers/add">Add Supplier</a>
         <% } %>
       </div>
<div class="table-container">
         <table  border="0">
         <thead>
           <th>#</th>
           <th>Name</th>
           <th>Products number</th>
           <% if (isAdmin) { %>
             <th></th>
           <% } %>
         </thead>
         <tbody>
           <% filtred.map(s=> { %>
             <tr class="<%= s.archived ? "archived" : "" %>">
               <td><%= s.id %></td>
               <td class="name"><%= s.supplier %></td>
               <td class="diver"><%= s.products_supplied %></td>
               <% if (isAdmin) { %>
                 <td class="actions">
                   <a class="edit-btn" href="/suppliers/edit/<%= s.id %>">Edit</a>
                   <form action="/suppliers/<%= s.id %>" method="POST">
                     <input type="hidden" name="_method" value="DELETE">
                     <button class="<%= s.archived ? "unarchive-btn" : "del-btn" %>" type="submit"><%= s.archived ? "Unarchive" : "Archive" %></button>
                   </form>
                 </td>
               <% } %>
             </tr>
           <% }) %>
         </tbody>
       </table>
</div>
     </section>
  </body>
</html>
